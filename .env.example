# ─────────────────────────────────────────────────────────────────────────────
# wcag-auditor  –  environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Required: Google Places API key
# Enable "Places API" in the Google Cloud Console:
#   https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=AIzaSyDQAh1dYo-m4uBUjWvf78olnC0IXlSFAr4

# Optional: set to "1" to print stack traces on errors
DEBUG=

# ── Email sending (GoDaddy SMTP) ──────────────────────────────────────────────
# Your full GoDaddy email address (e.g. you@yourdomain.com)
SMTP_USER=you@yourdomain.com

# Your GoDaddy email password (the one you use to log into Webmail)
SMTP_PASSWORD=your_email_password_here

# Display name shown to recipients in the From field
EMAIL_FROM_NAME=Your Name

# GoDaddy SMTP settings — these defaults work for most GoDaddy accounts
# Only change these if GoDaddy gives you different settings
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=587

